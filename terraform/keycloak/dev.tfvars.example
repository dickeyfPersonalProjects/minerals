# Example tfvars for local docker-compose dev.
# Copy to dev.tfvars and adjust as needed. dev.tfvars is gitignored.

keycloak_url_override   = "http://localhost:8080"
keycloak_admin_user     = "admin"
keycloak_admin_password = "admin"
env_domain              = "localhost"
realm_name              = "minerals"
realm_display_name      = "Minerals"
registration_allowed    = true
